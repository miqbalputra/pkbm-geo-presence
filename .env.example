# Frontend build
VITE_API_URL=/api
# Google Sign-In Client ID — opsional (fallback untuk dev lokal).
# Sumber utama: GOOGLE_CLIENT_ID runtime env via /api/google_config.php
VITE_GOOGLE_CLIENT_ID=

# App
APP_ENV=production
APP_URL=https://presensi.example.com
APP_TIMEZONE=Asia/Jakarta
CORS_ALLOWED_ORIGINS=https://presensi.example.com

# Google Sign-In (OAuth)
# Dapatkan Client ID di: https://console.cloud.google.com/apis/credentials
# Cukup set GOOGLE_CLIENT_ID (runtime env) — frontend ambil dari /api/google_config.php.
# VITE_GOOGLE_CLIENT_ID di bawah hanya fallback opsional untuk dev lokal.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=geogqpresence
DB_USER=geopresensi
DB_PASS=change-me
DB_TIMEZONE=+07:00

# Optional n8n/API integrations
N8N_API_KEY=change-this-long-random-key
HERMES_API_KEY=change-this-long-random-key-for-hermes
GOWA_WEBHOOK_URL=
GOWA_USERNAME=
GOWA_PASSWORD=
